    $3
assert excinfo.value
endsnippet

snippet aoc "advent of code" b
#!/usr/bin/env python
"""
$0

https://adventofcode.com/`!v strftime("%Y")`/day/`!v expand("%:p:h:t")->substitute('^day0*', '', '')``!v expand('%:t') =~ 'part2' ? '#part2' : ''`
"""

from __future__ import annotations

import argparse
import pathlib


parser = argparse.ArgumentParser()
parser.add_argument("filename", nargs="?", default="example")
parser.add_argument("-v", "--verbose", action="store_true")
args = parser.parse_args()
input_file = pathlib.Path(args.filename)
input_lines = input_file.read_text().splitlines()
endsnippet

pre_expand "add_import(snip, 'dataclasses', 'field')"
snippet field "dataclasses.field()"
field(default_factory=$1)$0
endsnippet

pre_expand "adjust_indent(snip, 0)"
post_expand "blank_lines_above(snip, 1); blank_lines_below(snip, (1, 2))"
snippet "(def )?parse" "aoc parse() helper" br
    @classmethod
    def parse(cls, s: str) -> ${1:Self}:
        return cls($2)$0
endsnippet

pre_expand "adjust_indent(snip, 4)"
post_expand "blank_lines_above(snip, 1); blank_lines_below(snip, (1, 2))"
snippet "(def )?(__)?enter(__)?" "context manager __enter__" br
def __enter__(self) -> ${1:Self}:
    return self
$0
endsnippet

pre_expand "adjust_indent(snip, 4)"
post_expand "blank_lines_above(snip, 1); blank_lines_below(snip, (1, 2))"
snippet "(def )?(__)?exit(__)?" "context manager __exit__" br
def __exit__(self, exc_type: Any, exc_value: Any, traceback: Any) -> None:
    ${1:pass}
endsnippet
